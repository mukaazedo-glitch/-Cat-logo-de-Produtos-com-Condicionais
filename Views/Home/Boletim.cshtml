@{
    ViewData["Title"] = "Boletim de Notas";
    var disciplinas = ViewBag.Disciplinas as List<string>;
    var notas = ViewBag.Notas as List<double>;
    double somaNotas = 0;
}

<h2>Meu Boletim de Notas</h2>

<table class="table table-striped" style="width: 100%; border-collapse: collapse; margin-top: 20px;">
    <thead>
        <tr style="background-color: #212529; color: white; text-align: left;">
            <th style="padding: 10px; border: 1px solid #ddd;">Disciplina</th>
            <th style="padding: 10px; border: 1px solid #ddd;">Nota</th>
            <th style="padding: 10px; border: 1px solid #ddd;">Status</th>
            <th style="padding: 10px; border: 1px solid #ddd;">Classificação</th>
        </tr>
    </thead>
    <tbody>
        @* Passo 3: Criando a tabela *@
        @for (int i = 0; i < disciplinas.Count; i++)
        {
            somaNotas += notas[i];
            
            <tr>
                <td style="padding: 10px; border: 1px solid #ddd;">@disciplinas[i]</td>
                <td style="padding: 10px; border: 1px solid #ddd;">@notas[i].ToString("F1")</td>
                
                @* Passo 4: @if para exibir Aprovado (verde) ou Reprovado (vermelho) *@
                <td style="padding: 10px; border: 1px solid #ddd;">
                    @if (notas[i] >= 6.0)
                    {
                        <span style="color: green; font-weight: bold;">Aprovado</span>
                    }
                    else
                    {
                        <span style="color: red; font-weight: bold;">Reprovado</span>
                    }
                </td>

                @* Passo 6: @switch para classificar em A, B, C ou D *@
                <td style="padding: 10px; border: 1px solid #ddd;">
                    @{
                        char letra;
                        switch (notas[i])
                        {
                            case double n when (n >= 9.0):
                                letra = 'A';
                                break;
                            case double n when (n >= 7.0):
                                letra = 'B';
                                break;
                            case double n when (n >= 5.0):
                                letra = 'C';
                                break;
                            default:
                                letra = 'D';
                                break;
                        }
                    }
                    <strong>@letra</strong>
                </td>
            </tr>
        }
        
        @* Passo 5: Média geral no final da tabela *@
        @{
            double mediaGeral = somaNotas / disciplinas.Count;
        }
        <tr style="background-color: #f8f9fa; font-weight: bold;">
            <td style="padding: 10px; border: 1px solid #ddd;" colspan="2">Média Geral:</td>
            <td style="padding: 10px; border: 1px solid #ddd;" colspan="2">@mediaGeral.ToString("F1")</td>
        </tr>
    </tbody>
</table>